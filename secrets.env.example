# Copy this to secrets.env and fill in values. chmod 600 secrets.env. Never commit secrets.env.

# Ecowitt gateway PASSKEY — set the same value in the GW1200 "Custom Server" config.
# Any random alphanumeric string works; e.g. `openssl rand -hex 16`
INGEST_PASSKEY=your_passkey_here

# Telegram bot token from @BotFather and your personal chat ID.
# Get your chat ID: send a message to the bot, then
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321

# Anthropic API key for LLM prose generation (Stage 8).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# SQLite database file path (absolute or relative to the project root).
DB_PATH=garden.sqlite3

# Location for weather-aware advice (Open-Meteo — no API key needed).
# GARDEN_ZIPCODE + GARDEN_COUNTRY are geocoded automatically on first run.
GARDEN_ZIPCODE=60007
GARDEN_COUNTRY=us
GARDEN_TIMEZONE=America/Chicago   # IANA timezone — used to time the morning brief

# Optional: set coordinates directly to skip zipcode geocoding.
# GARDEN_LAT=
# GARDEN_LON=
